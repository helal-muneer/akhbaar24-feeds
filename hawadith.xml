      <title>القبض على 8 مخالفين لتهريبهم 160 كجم من القات</title>
      <link>https://www.akhbaar24.com/%D8%AD%D9%88%D8%A7%D8%AF%D8%AB/%D8%A7%D9%84%D9%82%D8%A8%D8%B6-%D8%B9%D9%84%D9%89-8-%D9%85%D8%AE%D8%A7%D9%84%D9%81%D9%8A%D9%86-%D9%84%D8%AA%D9%87%D8%B1%D9%8A%D8%A8%D9%87%D9%85-160-%D9%83%D8%AC%D9%85-%D9%85%D9%86-%D8%A7%D9%84%D9%82%D8%A7%D8%AA-764767</link>
