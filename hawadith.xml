      <title>القبض على يمنيين لترويجهما 27 كجم من الحشيش بعسير</title>
      <link>https://www.akhbaar24.com/%D8%AD%D9%88%D8%A7%D8%AF%D8%AB/%D8%A7%D9%84%D9%82%D8%A8%D8%B6-%D8%B9%D9%84%D9%89-%D9%8A%D9%85%D9%86%D9%8A%D9%8A%D9%86-%D9%84%D8%AA%D8%B1%D9%88%D9%8A%D8%AC%D9%87%D9%85%D8%A7-27-%D9%83%D8%AC%D9%85-%D9%85%D9%86-%D8%A7%D9%84%D8%AD%D8%B4%D9%8A%D8%B4-%D8%A8%D8%B9%D8%B3%D9%8A%D8%B1-763899</link>
      <guid isPermaLink="true">https://www.akhbaar24.com/%D8%AD%D9%88%D8%A7%D8%AF%D8%AB/%D8%A7%D9%84%D9%82%D8%A8%D8%B6-%D8%B9%D9%84%D9%89-%D9%8A%D9%85%D9%86%D9%8A%D9%8A%D9%86-%D9%84%D8%AA%D8%B1%D9%88%D9%8A%D8%AC%D9%87%D9%85%D8%A7-27-%D9%83%D8%AC%D9%85-%D9%85%D9%86-%D8%A7%D9%84%D8%AD%D8%B4%D9%8A%D8%B4-%D8%A8%D8%B9%D8%B3%D9%8A%D8%B1-763899</guid>
