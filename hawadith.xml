      <title>القبض على مخالف ومقيم بالرياض لترويجهما 7 آلاف قرص خاضع للتداول</title>
      <link>https://www.akhbaar24.com/%D8%AD%D9%88%D8%A7%D8%AF%D8%AB/%D8%A7%D9%84%D9%82%D8%A8%D8%B6-%D8%B9%D9%84%D9%89-%D9%85%D8%AE%D8%A7%D9%84%D9%81-%D9%88%D9%85%D9%82%D9%8A%D9%85-%D8%A8%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D9%84%D8%AA%D8%B1%D9%88%D9%8A%D8%AC%D9%87%D9%85%D8%A7-7-%D8%A2%D9%84%D8%A7%D9%81-%D9%82%D8%B1%D8%B5-%D8%AE%D8%A7%D8%B6%D8%B9-%D9%84%D9%84%D8%AA%D8%AF%D8%A7%D9%88%D9%84-764513</link>
