      <title>إخماد حريق في مركبة بالمدينة المنورة</title>
      <link>https://www.akhbaar24.com/%D8%AD%D9%88%D8%A7%D8%AF%D8%AB/%D8%A5%D8%AE%D9%85%D8%A7%D8%AF-%D8%AD%D8%B1%D9%8A%D9%82-%D9%81%D9%8A-%D9%85%D8%B1%D9%83%D8%A8%D8%A9-%D8%A8%D8%A7%D9%84%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D9%88%D8%B1%D8%A9-763760</link>
