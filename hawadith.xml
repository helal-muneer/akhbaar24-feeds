      <title>"الأمن البيئي" يضبط مخالفًا لنقله حطبًا محليًّا في المدينة</title>
      <link>https://www.akhbaar24.com/%D8%AD%D9%88%D8%A7%D8%AF%D8%AB/%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D9%8A-%D9%8A%D8%B6%D8%A8%D8%B7-%D9%85%D8%AE%D8%A7%D9%84%D9%81%D8%A7-%D9%84%D9%86%D9%82%D9%84%D9%87-%D8%AD%D8%B7%D8%A8%D8%A7-%D9%85%D8%AD%D9%84%D9%8A%D8%A7-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D8%AF%D9%8A%D9%86%D8%A9-763939</link>
